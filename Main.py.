import os
import time
import requests
from flask import Flask
from threading import Thread

# --- SERVER PER RENDER (Anti-sospensione) ---
app = Flask('')
@app.route('/')
def home(): return "Bot Online"

def run(): app.run(host='0.0.0.0', port=8080)

# --- CONFIGURAZIONE ---
TOKEN = os.getenv("TELEGRAM_TOKEN")
CHAT_ID = os.getenv("TELEGRAM_CHAT_ID")

def invia_alert(messaggio):
    # Link per aprire l'app TradingView direttamente
    link_app = "tradingview://chart/?symbol=OANDA:XAUUSD&interval=15"
    testo_finale = f"{messaggio}\n\n🔗 [APRI APP TRADINGVIEW]({link_app})"
    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage?chat_id={CHAT_ID}&text={testo_finale}&parse_mode=Markdown"
    requests.get(url)

if __name__ == "__main__":
    # Avvia il server web in parallelo
    Thread(target=run).start()
    
    print("Bot in ascolto...")
    # Qui il bot farà i suoi controlli (Stocastico, ecc.)
    # Esempio di invio:
    # invia_alert("🚀 GOLD BUY: Incrocio Stocastico!")
    while True:
        time.sleep(60)
